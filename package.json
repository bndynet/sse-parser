{
  "name": "@bndynet/sse-parser",
  "version": "0.1.2",
  "description": "Zero-dependency SSE and NDJSON stream parser with AI API adapters (OpenAI, Anthropic, Gemini, Ollama)",
  "type": "module",
  "author": "Bendy Zhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bndynet/sse-parser.git"
  },
  "bugs": {
    "url": "https://github.com/bndynet/sse-parser/issues"
  },
  "homepage": "https://github.com/bndynet/sse-parser/tree/main/packages/sse-parser#readme",
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck",
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run lint && npm run test && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "sse",
    "server-sent-events",
    "ndjson",
    "streaming",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "parser"
  ],
  "license": "MIT"
}
